{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd apps/zelaxy && bun install",
    "watchPatterns": [
      "apps/zelaxy/worker/**",
      "apps/zelaxy/lib/**",
      "apps/zelaxy/db/**",
      "apps/zelaxy/executor/**",
      "apps/zelaxy/package.json"
    ]
  },
  "deploy": {
    "startCommand": "cd apps/zelaxy && bun run start:worker",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
